{
  "name": "teslacam-browser",
  "productName": "TeslaCam Browser",
  "version": "0.0.958",
  "description": "A minimal TeslaCam Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder build",
    "publish": "electron-builder build --mac --win --linux -p always"
  },
  "repository": "https://github.com/mhaluska/teslacam-browser",
  "keywords": [
    "Electron",
    "Tesla",
    "TeslaCam",
    "browser"
  ],
  "author": "Chris Cavanagh <teslacam@chriscavanagh.com>",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "build": {
    "appId": "cjc-teslacam-browser",
    "publish": [
      {
        "provider": "github",
        "owner": "bobstrogg",
        "repo": "teslacam-browser"
      }
    ],
    "mac": {
      "publish": [
        "github"
      ],
      "icon": "build/icons/icon.icns",
      "target": [
        "pkg",
        "zip"
      ]
    },
    "linux": {
      "publish": [
        "github"
      ],
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "publish": [
        "github"
      ],
      "target": "NSIS",
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.2"
  },
  "dependencies": {
    "bootstrap": "^4.6.2",
    "electron-settings": "^3.2.0",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "flatpickr": "^4.6.13",
    "jquery": "^3.7.1",
    "open-iconic": "^1.1.1",
    "popper.js": "^1.16.1",
    "protobufjs": "^7.5.4",
    "serve-index": "^1.9.2",
    "vue": "^2.7.16"
  },
  "postinstall": "electron-builder install-app-deps"
}
