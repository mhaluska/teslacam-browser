{
  "name": "teslacam-browser",
  "productName": "TeslaCam Browser",
  "version": "0.1.22",
  "description": "A minimal TeslaCam Browser",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "hash-password": "node scripts/hash-password.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": "https://github.com/mhaluska/teslacam-browser",
  "keywords": [
    "Electron",
    "Tesla",
    "TeslaCam",
    "browser"
  ],
  "author": "Chris Cavanagh <teslacam@chriscavanagh.com>",
  "contributors": [
    "Marek Haluska <marek.h@luska.email>"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "build": {
    "appId": "com.mhaluska.teslacam-browser",
    "productName": "TeslaCam Browser",
    "publish": {
      "provider": "github"
    },
    "icon": "images/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": "NSIS"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.2",
    "lefthook": "^2.1.6",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "compression": "^1.8.1",
    "electron-settings": "^4.0.4",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "flatpickr": "^4.6.13",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "protobufjs": "^8.0.1",
    "uplot": "^1.6.32",
    "vue": "^3.5.32"
  },
  "postinstall": "electron-builder install-app-deps"
}
